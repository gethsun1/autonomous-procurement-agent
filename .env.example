# ============================================================
#  Autonomous Procurement Agent — Environment Configuration
#  Copy this file to .env and fill in ALL values.
#  The system will CRASH at startup if any required var is missing.
# ============================================================

# ── REQUIRED: Google Gemini AI ────────────────────────────────
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ── REQUIRED: SKALE Network ───────────────────────────────────
# Chain: SKALE Base Sepolia Testnet
# Explorer: https://base-sepolia-testnet-explorer.skalenodes.com/
SKALE_RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/jubilant-horrible-ancha
SKALE_CHAIN_ID=324705682

# ── REQUIRED: Deployer Wallet ─────────────────────────────────
# Private key of the wallet used to deploy contracts and sign txs.
# NEVER commit a real private key. Fund with SKALE Base Sepolia CREDIT.
# Faucet: https://sfuel.skale.network/
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# ── REQUIRED: Encryption ──────────────────────────────────────
# 32+ char random string. Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_char_minimum_encryption_key_here

# ── Contract Addresses (populated after `npm run deploy`) ─────
PROCUREMENT_WORKFLOW_ADDRESS=
X402_ESCROW_ADDRESS=
AP2_SETTLEMENT_ADDRESS=
ENCRYPTION_HELPER_ADDRESS=
ERC8004_REGISTRY_ADDRESS=

# ── Backend Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SKALE_RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/jubilant-horrible-ancha
NEXT_PUBLIC_SKALE_CHAIN_ID=324705682

# ── Payment Demo Transparency ─────────────────────────────────
# Demo scales payment amounts by this divisor so testnet sFUEL balances
# are sufficient. Set to 1 for production (real amounts).
# This value is DISPLAYED in the UI — no hidden scaling.
PAYMENT_SCALE_DIVISOR=1000000
